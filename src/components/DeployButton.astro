---
export interface Props {
  language: string;
  template?: string;
}

const { language, template = "hello-world" } = Astro.props;
---

<a
  href="#"
  class="deploy-button"
  title="Deploy flow coming soon — will handle auth redirect + post-signup resume"
>
  Deploy to Origin Clouds →
</a>

<style is:global>
  .deploy-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: linear-gradient(135deg, #059669, #10b981);
    color: white;
    font-weight: 600;
    border-radius: 0.5rem;
    text-decoration: none;
    font-size: 1rem;
    transition: opacity 0.2s, transform 0.2s;
    cursor: default;
    opacity: 0.6;
  }

  .deploy-button:hover {
    opacity: 0.8;
    transform: translateY(-1px);
  }
</style>
